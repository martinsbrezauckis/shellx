{
  "name": "grok-shell",
  "version": "0.1.29",
  "description": "Cross-platform desktop shell for grok-build and any ACP-speaking agent",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/martinsbrezauckis/shellx.git"
  },
  "homepage": "https://github.com/martinsbrezauckis/shellx#readme",
  "type": "module",
  "scripts": {
    "capture": "tsx scripts/acp-driver.ts --mode=stdio",
    "drive": "tsx scripts/acp-driver.ts --mode=app",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test-media-extraction.ts && tsx scripts/test-permission-pill.ts && tsx scripts/test-voice-chat.ts",
    "lint": "tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@fontsource-variable/onest": "^5.2.11",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "xterm": "^5.3.0"
  }
}
