{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "core:webview:default",
      "allow": [
        { "path": "$HOME/.grok/**" },
        { "path": "/home/**/.grok/**" },
        { "path": "$APPDATA/.grok/**" },
        { "path": "$LOCALAPPDATA/.grok/**" },
        { "path": "/tmp/shellx-*/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:default",
    "notification:default"
  ]
}
